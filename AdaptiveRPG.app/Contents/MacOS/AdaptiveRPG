#!/bin/bash
# Adaptive RPG Battle - macOS App Bundle Entry Point

# Get the directory of this script
DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"
PROJECT_DIR="${DIR}/../../../"

# Set Qt platform to cocoa (macOS native)
export QT_QPA_PLATFORM=cocoa

# Find Qt plugins
QT_PLUGIN_PATH="$(python3 -c "import PySide6; import os; print(os.path.join(os.path.dirname(PySide6.__file__), 'Qt', 'plugins'))" 2>/dev/null)"
if [ -d "$QT_PLUGIN_PATH" ]; then
    export QT_QPA_PLATFORM_PLUGIN_PATH="$QT_PLUGIN_PATH"
fi

# Also check homebrew paths
for path in \
    "/opt/homebrew/lib/qt6/plugins" \
    "/opt/homebrew/Cellar/qt@6/*/lib/qt6/plugins" \
    "/usr/local/lib/qt6/plugins" \
    "/usr/local/Cellar/qt@6/*/lib/qt6/plugins" \
    "$HOME/.local/lib/python3.*/site-packages/PySide6/Qt/plugins" \
    "/opt/homebrew/lib/python3.*/site-packages/PySide6/Qt/plugins"; do
    if [ -d "$path" ] && [ -d "$path/platforms" ]; then
        export QT_QPA_PLATFORM_PLUGIN_PATH="$path"
        break
    fi
done

# Set Python path
export PYTHONPATH="${PROJECT_DIR}:${PYTHONPATH}"

# Run the game
cd "${PROJECT_DIR}"
exec python3 main.py "$@"